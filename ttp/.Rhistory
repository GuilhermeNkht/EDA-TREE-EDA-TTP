library(tidyverse)
library(tidyverse)
install.packages("tidyverse")
library(tidyverse)
library(tidyverse)
install.packages("dplyr")
install.packages("ggplot2")
library(tidyverse)
library(dplyr)
library(ggplot2)
base_folder <- "results"
files <- list.files(base_folder,
pattern="\\.csv$",
recursive = TRUE,
full.names = TRUE)
all_data <- data.frame()
for (f in files)
{
df <- read.csv(f)
path_parts <- strsplit(f, "/")[[1]]
initialization <- path_parts[2]
algorithm <- path_parts[3]
local_search <- path_parts[4]
df$initialization <- initialization
df$algorithm <- algorithm
df$local_search <- local_search
df$run <- basename(f)
all_data <- rbind(all_data, df)
}
